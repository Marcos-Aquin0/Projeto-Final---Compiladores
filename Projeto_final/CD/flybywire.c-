int processoAtual;

void verify(int comando, int valor, int temp, int combustivel, int altura){
    int newtemp;
    int newcombustivel;
    int newaltura;
    int aux;

    aux = 12000 + 200*(processoAtual);

    if (comando == 1) { 
        newaltura = altura + valor;
        newtemp = temp + 5; 
        newcombustivel = combustivel - (valor - 20); 
    } 
    else if (comando == 2) { 
        newaltura = altura - valor;
        newtemp = temp - 3; 
        newcombustivel = combustivel - (valor - 10); 
    }
    else {
        nop();
    }
    output(52);
    saveword(aux-10, newtemp);
    saveword(aux-11, newcombustivel);
    saveword(aux-12, newaltura); 
}

void flybyw(){ 
    int header ;
    int flag ;
    int comando ;
    int valor ;
    int checksum ;
    int temp ;
    int combustivel ;
    int altura ;
    int newtemp;
    int newcombustivel;
    int newaltura;

    msgLcd(30); 

    header = loadword(500);
    flag = loadword(501);
    comando = loadword(502);
    valor = loadword(503);
    checksum = loadword(504);

    temp = loadword(2000);
    combustivel = loadword(2001);
    altura = loadword(2002);
    
    verify(comando, valor, temp, combustivel, altura);
   
}

void main (void){
    flybyw();
    saltoSO();
}